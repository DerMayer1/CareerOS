{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DerMayer1/CareerOS/schemas/sources.schema.json",
  "title": "CareerOS sources configuration",
  "type": "object",
  "required": ["default_limit", "cache_ttl_hours", "sources"],
  "properties": {
    "default_limit": { "type": "number", "minimum": 1, "maximum": 1000 },
    "cache_ttl_hours": { "type": "number", "minimum": 0, "maximum": 8760 },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "type", "phase"],
        "properties": {
          "enabled": { "type": "boolean" },
          "type": { "type": "string", "minLength": 1 },
          "phase": { "type": "number" },
          "max_limit": { "type": "number", "minimum": 0, "maximum": 1000 },
          "base_url": { "type": "string" },
          "feed_url": { "type": "string" },
          "search_url_template": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
